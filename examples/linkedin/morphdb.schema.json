{
  "morphdb_schema_version": 1,
  "app": "linkedin-demo",
  "types": [
    {
      "name": "person",
      "fields": {
        "name": { "type": "string", "index": true },
        "headline": "string",
        "location": { "type": "string", "index": true },
        "about": "string"
      },
      "relations": {
        "connections": {
          "to": "person",
          "cardinality": "many_to_many",
          "symmetric": true,
          "description": "Mutual professional connections. Symmetric: linking A to B also links B to A — one shared edge, traversed from either side, so there is no separate inverse name."
        }
      }
    },
    {
      "name": "post",
      "fields": {
        "body": "string",
        "created": { "type": "datetime", "index": true },
        "likes": { "type": "number", "index": true, "default": 0 }
      },
      "relations": {
        "author": {
          "to": "person",
          "cardinality": "many_to_one",
          "inverse": "posts",
          "description": "The person who wrote this post (one author per post).",
          "inverse_description": "Posts this person has authored; the feed reads these back, newest first."
        }
      }
    },
    {
      "name": "job",
      "fields": {
        "title": "string",
        "company": { "type": "string", "index": true },
        "location": { "type": "string", "index": true },
        "description": "string"
      },
      "relations": {}
    }
  ]
}

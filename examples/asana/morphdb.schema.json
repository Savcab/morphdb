{
  "morphdb_schema_version": 1,
  "app": "asana-demo",
  "types": [
    {
      "name": "user",
      "fields": {
        "name": "string",
        "avatar": "string"
      },
      "relations": {}
    },
    {
      "name": "project",
      "fields": {
        "name": "string",
        "color": "string"
      },
      "relations": {}
    },
    {
      "name": "section",
      "fields": {
        "name": "string",
        "order": { "type": "number", "index": true }
      },
      "relations": {
        "project": {
          "to": "project",
          "cardinality": "many_to_one",
          "inverse": "sections"
        }
      }
    },
    {
      "name": "task",
      "fields": {
        "title": "string",
        "notes": "string",
        "done": { "type": "boolean", "index": true, "default": false },
        "due": { "type": "datetime", "index": true },
        "order": { "type": "number", "index": true }
      },
      "relations": {
        "project": {
          "to": "project",
          "cardinality": "many_to_one",
          "inverse": "tasks"
        },
        "section": {
          "to": "section",
          "cardinality": "many_to_one",
          "inverse": "tasks"
        },
        "assignee": {
          "to": "user",
          "cardinality": "many_to_one",
          "inverse": "assigned"
        }
      }
    }
  ]
}
